# PartyKit WebSocket server URL (without https://)
#
# For local development:
#   NEXT_PUBLIC_PARTYKIT_HOST=localhost:1999
#
# For production (deployed PartyKit server):
#   NEXT_PUBLIC_PARTYKIT_HOST=feed-the-kraken-companion.toumas.partykit.dev

# Resend email API key (EU region) - get from resend.com
RESEND_API_KEY=re_xxx
# Email address where you want to receive feedback
FEEDBACK_EMAIL=your@email.com
